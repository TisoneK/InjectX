{
  "name": "injectx",
  "version": "0.4.0",
  "description": "InjectX — Universal VPN tunnel config reader (EHI, HC, HAT, DARK, TLS, NPV, NSH)",
  "main": "frontend/main.js",
  "scripts": {
    "start": "electron .",
    "start:dev": "NODE_ENV=development electron .",
    "backend": "cd backend && python main.py",
    "install:backend": "cd backend && pip install -r requirements.txt",
    "dist": "electron-builder"
  },
  "keywords": [
    "vpn",
    "config",
    "ehi",
    "hc",
    "hat",
    "dark",
    "tls",
    "npv4",
    "nsh",
    "http-injector",
    "ha-tunnel",
    "napsternetv",
    "sockshttp",
    "http-custom",
    "dark-tunnel"
  ],
  "author": "Tisone Kironget <tisonkironget@gmail.com>",
  "license": "MIT",
  "build": {
    "appId": "com.tisonek.injectx",
    "productName": "InjectX",
    "directories": {
      "output": "dist"
    },
    "files": [
      "frontend/**/*",
      "backend/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icons/icon.ico",
      "target": "nsis"
    },
    "mac": {
      "icon": "assets/icons/icon.png",
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "icon": "assets/icons/icon.png",
      "target": "AppImage",
      "category": "Network"
    }
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "overrides": {
    "fast-uri": "^3.1.4"
  }
}
